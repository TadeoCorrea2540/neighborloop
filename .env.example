# ============================================================
# NeighborLoop — environment variables (EXAMPLE / template)
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored and must NEVER be committed.
# ============================================================

# Supabase project URL.
# Dashboard → Project Settings → Data API (or API) → "Project URL".
NEXT_PUBLIC_SUPABASE_URL=

# Supabase PUBLISHABLE key (safe for the browser; anon-equivalent).
# Dashboard → Project Settings → API keys → "Publishable" (or legacy "anon").
# This value is exposed to client code by design — that is expected and safe.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ------------------------------------------------------------
# DO NOT add a service-role / secret key as a NEXT_PUBLIC_* variable.
# Public (NEXT_PUBLIC_*) vars are bundled into the browser. A service-role key
# bypasses Row Level Security and must stay server-only.
#
# When a future server-only admin task needs it (Phase 6+), add it as a
# PRIVATE, server-only variable (no NEXT_PUBLIC_ prefix), e.g.:
#   SUPABASE_SERVICE_ROLE_KEY=
# It is NOT required or used anywhere in Phase 2.
# ------------------------------------------------------------

# ------------------------------------------------------------
# AI Mission Builder (Gemini) — server-only, OPTIONAL.
# Used by the organizer "Draft with AI" flow to generate a mission draft.
# Get a key: https://aistudio.google.com/app/apikey
# Server-only (no NEXT_PUBLIC_ prefix) — never exposed to the browser.
# If unset, the manual mission form works exactly as before; the AI flow
# simply returns a friendly "unavailable" message.
GEMINI_API_KEY=

# Optional model override (defaults to gemini-2.5-flash).
# GEMINI_MODEL=
# ------------------------------------------------------------
